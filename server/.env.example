# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Get this from MongoDB Atlas > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eventify?retryWrites=true&w=majority

# Any long random string — used to sign login tokens
JWT_SECRET=replace_this_with_a_long_random_secret_string

# Port the backend will run on
PORT=5000
